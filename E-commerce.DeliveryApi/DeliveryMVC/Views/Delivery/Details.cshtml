@model DeliveryMVC.Models.DeliveryViewModel
@{
    Layout = null;
    string StatusBadge(string s) => s switch {
        "Pending"        => "bg-secondary",
        "Packed"         => "bg-info text-dark",
        "Shipped"        => "bg-primary",
        "OutForDelivery" => "bg-warning text-dark",
        "Delivered"      => "bg-success",
        "Failed"         => "bg-danger",
        _                => "bg-light text-dark"
    };
    string StatusIcon(string s) => s switch {
        "Pending"        => "bi-hourglass-split",
        "Packed"         => "bi-box-seam",
        "Shipped"        => "bi-truck",
        "OutForDelivery" => "bi-bicycle",
        "Delivered"      => "bi-check-circle-fill",
        "Failed"         => "bi-x-circle-fill",
        _                => "bi-circle"
    };
    string StatusLabel(string s) => s == "OutForDelivery" ? "Out for Delivery" : s;

    var nextMap = new Dictionary<string, string[]>
    {
        ["Pending"]        = new[] { "Packed",         "Failed" },
        ["Packed"]         = new[] { "Shipped",         "Failed" },
        ["Shipped"]        = new[] { "OutForDelivery",  "Failed" },
        ["OutForDelivery"] = new[] { "Delivered",       "Failed" },
        ["Delivered"]      = Array.Empty<string>(),
        ["Failed"]         = new[] { "Pending" },
    };
    var allowedNext = nextMap.ContainsKey(Model.Status) ? nextMap[Model.Status] : Array.Empty<string>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Delivery #@Model.Id</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f1f5f9; }
        .sidebar { width: 240px; min-height: 100vh; background: #0f172a; position: fixed; top: 0; left: 0; z-index: 100; }
        .sidebar-brand { padding: 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,.07); display: flex; align-items: center; gap: .65rem; }
        .logo-icon { width: 34px; height: 34px; background: #2563eb; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
        .sidebar-brand span { color: #f1f5f9; font-weight: 700; font-size: 1rem; }
        .nav-link-s { color: #94a3b8; border-radius: 8px; padding: .55rem .85rem; display: flex; align-items: center; gap: .6rem; font-size: .875rem; font-weight: 500; text-decoration: none; transition: all .15s; margin: .1rem .75rem; }
        .nav-link-s:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
        .main-content { margin-left: 240px; padding: 2rem; }
        .card { border: 1px solid #e2e8f0; border-radius: 14px; box-shadow: 0 1px 4px rgba(0,0,0,.05); }
        .card-head { padding: 1rem 1.25rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: .6rem; }
        .head-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: .9rem; }
        .info-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; margin-bottom: .15rem; }
        .info-value { font-size: .875rem; color: #1e293b; font-weight: 500; }
        /* Timeline */
        .timeline { position: relative; padding-left: 2rem; }
        .timeline::before { content: ''; position: absolute; left: .65rem; top: 0; bottom: 0; width: 2px; background: #e2e8f0; }
        .tl-item { position: relative; padding-bottom: 1.25rem; }
        .tl-item:last-child { padding-bottom: 0; }
        .tl-dot { position: absolute; left: -1.53rem; top: .2rem; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .65rem; z-index: 1; }
        .tl-dot.current { box-shadow: 0 0 0 4px rgba(37,99,235,.15); }
        /* Products */
        .product-row { padding: .75rem 0; border-bottom: 1px solid #f1f5f9; }
        .product-row:last-child { border-bottom: none; }
        /* Action card */
        .action-card { background: linear-gradient(135deg,#f8fafc,#eff6ff); border: 1.5px solid #bfdbfe; }
        .deliver-card { background: #f0fdf4; border: 1.5px solid #bbf7d0; }
        .badge { font-size: .75rem; padding: .38em .65em; border-radius: 6px; }
        .alert { border-radius: 10px; border: none; }
        @@media (max-width: 991px) { .sidebar { display: none; } .main-content { margin-left: 0; } }
    </style>
</head>
<body>

<!-- Sidebar -->
<nav class="sidebar d-flex flex-column">
    <div class="sidebar-brand">
        <div class="logo-icon"><i class="bi bi-truck-front-fill text-white"></i></div>
        <span>DeliveryOps</span>
    </div>
    <div class="pt-2">
        <a class="nav-link-s" href="/Delivery"><i class="bi bi-arrow-left-circle"></i> Back to List</a>
        <a class="nav-link-s" href="/Delivery/Tracking/@Model.TrackingId"><i class="bi bi-geo-alt"></i> Track on Map</a>
    </div>
</nav>

<div class="main-content">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a href="/Delivery" class="text-muted text-decoration-none small">
                    <i class="bi bi-house"></i> Deliveries
                </a>
                <span class="text-muted small">/</span>
                <span class="text-muted small">@Model.TrackingId</span>
            </div>
            <h4 class="fw-bold mb-0">Delivery #@Model.Id</h4>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge @StatusBadge(Model.Status) fs-6">
                <i class="bi @StatusIcon(Model.Status) me-1"></i>@StatusLabel(Model.Status)
            </span>
            <a href="/Delivery/Tracking/@Model.TrackingId" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-geo-alt me-1"></i>Track on Map
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    <div class="row g-3">

        <!-- LEFT column -->
        <div class="col-lg-8">

            <!-- Recipient Info -->
            <div class="card mb-3">
                <div class="card-head">
                    <div class="head-icon" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-person-fill"></i></div>
                    <span class="fw-semibold">Recipient & Delivery Info</span>
                </div>
                <div class="card-body p-3">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="info-label">Recipient</div>
                            <div class="info-value">@Model.RecipientName</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="info-label">Phone</div>
                            <div class="info-value">@Model.ContactPhone</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="info-label">Order ID</div>
                            <div class="info-value">#@Model.OrderId</div>
                        </div>
                        <div class="col-sm-8">
                            <div class="info-label">Delivery Address</div>
                            <div class="info-value">@Model.FullAddress</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="info-label">Tracking ID</div>
                            <div class="info-value" style="font-family:monospace;font-size:.82rem;">@Model.TrackingId</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="info-label">Created</div>
                            <div class="info-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                        <div class="col-sm-4">
                            <div class="info-label">Estimated Delivery</div>
                            <div class="info-value @(Model.EstimatedDeliveryDate < DateTime.Now && Model.Status != "Delivered" ? "text-danger" : "")">
                                @Model.EstimatedDeliveryDate.ToString("dd MMM yyyy")
                                @if (Model.EstimatedDeliveryDate < DateTime.Now && Model.Status != "Delivered")
                                { <small>(Overdue)</small> }
                            </div>
                        </div>
                        @if (Model.ActualDeliveryDate.HasValue)
                        {
                            <div class="col-sm-4">
                                <div class="info-label">Delivered On</div>
                                <div class="info-value text-success">@Model.ActualDeliveryDate.Value.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.DeliveryAgentName))
                        {
                            <div class="col-sm-4">
                                <div class="info-label">Agent</div>
                                <div class="info-value">@Model.DeliveryAgentName</div>
                            </div>
                            <div class="col-sm-4">
                                <div class="info-label">Agent Phone</div>
                                <div class="info-value">@Model.DeliveryAgentPhone</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Products -->
            <div class="card mb-3">
                <div class="card-head">
                    <div class="head-icon" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-bag-fill"></i></div>
                    <span class="fw-semibold">Products (@Model.Items.Count items)</span>
                </div>
                <div class="card-body p-3">
                    @foreach (var item in Model.Items)
                    {
                        <div class="product-row d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:42px;height:42px;background:#f1f5f9;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-box text-muted"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">@item.ProductName</div>
                                    <div class="text-muted" style="font-size:.75rem;">₹@item.UnitPrice.ToString("N0") × @item.Quantity</div>
                                </div>
                            </div>
                            <div class="fw-bold">₹@item.LineTotal.ToString("N0")</div>
                        </div>
                    }
                    <div class="d-flex justify-content-end pt-2 mt-1 border-top">
                        <strong>Total: ₹@Model.Items.Sum(i => i.LineTotal).ToString("N0")</strong>
                    </div>
                </div>
            </div>

            <!-- Status History Timeline -->
            <div class="card">
                <div class="card-head">
                    <div class="head-icon" style="background:#fef9c3;color:#ca8a04;"><i class="bi bi-clock-history"></i></div>
                    <span class="fw-semibold">Status History</span>
                </div>
                <div class="card-body p-3 pt-4">
                    @if (Model.History.Any())
                    {
                        <div class="timeline">
                            @foreach (var h in Model.History.OrderByDescending(x => x.Timestamp))
                            {
                                var dotBg = h.Status == "Delivered" ? "#16a34a"
                                    : h.Status == "Failed" ? "#dc2626"
                                    : h.Status == Model.Status ? "#2563eb" : "#22c55e";
                                <div class="tl-item">
                                    <div class="tl-dot @(h.Status == Model.Status ? "current" : "")"
                                         style="background:@dotBg; color:#fff;">
                                        <i class="bi @StatusIcon(h.Status)"></i>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-semibold small" style="color:@dotBg;">@StatusLabel(h.Status)</div>
                                            @if (!string.IsNullOrEmpty(h.Remarks))
                                            { <div class="text-muted small">@h.Remarks</div> }
                                            @if (!string.IsNullOrEmpty(h.Location))
                                            { <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@h.Location</div> }
                                            <div class="text-muted small"><i class="bi bi-person me-1"></i>@h.UpdatedBy</div>
                                        </div>
                                        <div class="text-muted small text-end">@h.Timestamp.ToString("dd MMM HH:mm")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else { <p class="text-muted small">No history yet.</p> }
                </div>
            </div>
        </div>

        <!-- RIGHT column -->
        <div class="col-lg-4">

            <!-- Update Status -->
            <div class="card action-card mb-3">
                <div class="card-head">
                    <div class="head-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="bi bi-arrow-repeat"></i></div>
                    <span class="fw-semibold">Update Status</span>
                </div>
                <div class="card-body p-3">
                    <p class="text-muted small mb-3">
                        Current: <span class="badge @StatusBadge(Model.Status)">@StatusLabel(Model.Status)</span>
                    </p>
                    @if (allowedNext.Length > 0)
                    {
                        <form method="post" action="/Delivery/UpdateStatus">
                            <input type="hidden" name="deliveryId" value="@Model.Id"/>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Move to Status</label>
                                <select name="status" class="form-select form-select-sm">
                                    @foreach (var ns in allowedNext)
                                    {
                                        <option value="@ns">@StatusLabel(ns)</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-arrow-right-circle me-1"></i>Update Status
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success py-2 mb-0 small">
                            <i class="bi bi-check-circle-fill me-1"></i>Terminal state — no further updates.
                        </div>
                    }
                </div>
            </div>

            <!-- Mark Delivered (checkbox) -->
            @if (Model.Status == "OutForDelivery")
            {
                <div class="card deliver-card mb-3">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-1"><i class="bi bi-check-circle-fill text-success me-2"></i>Confirm Delivery</h6>
                        <p class="text-muted small mb-3">Confirm package was handed to the recipient.</p>
                        <form method="post" action="/Delivery/MarkDelivered"
                              onsubmit="return confirm('Mark as Delivered for @Model.RecipientName?')">
                            <input type="hidden" name="deliveryId" value="@Model.Id"/>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="confirmCheck" required/>
                                <label class="form-check-label small fw-semibold" for="confirmCheck">
                                    I confirm delivery was completed
                                </label>
                            </div>
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                <i class="bi bi-check2-circle me-1"></i>Mark as Delivered
                            </button>
                        </form>
                    </div>
                </div>
            }

            <!-- GPS -->
            @if (Model.CurrentLatitude.HasValue)
            {
                <div class="card mb-3">
                    <div class="card-head">
                        <div class="head-icon" style="background:#fef3c7;color:#d97706;"><i class="bi bi-geo-alt-fill"></i></div>
                        <span class="fw-semibold">Current Location</span>
                    </div>
                    <div class="card-body p-3">
                        <div class="small text-muted mb-2" style="font-family:monospace;">
                            @Model.CurrentLatitude.Value.ToString("F4")°N,
                            @Model.CurrentLongitude!.Value.ToString("F4")°E
                        </div>
                        <a href="/Delivery/Tracking/@Model.TrackingId" class="btn btn-outline-warning btn-sm w-100">
                            <i class="bi bi-map me-1"></i>Open Tracking Map
                        </a>
                    </div>
                </div>
            }

            <!-- Transition Guide -->
            <div class="card">
                <div class="card-head">
                    <div class="head-icon" style="background:#faf5ff;color:#7c3aed;"><i class="bi bi-diagram-2"></i></div>
                    <span class="fw-semibold small">Valid Flow</span>
                </div>
                <div class="card-body p-3">
                    @{
                        var flowSteps = new[] { "Pending", "Packed", "Shipped", "OutForDelivery", "Delivered" };
                    }
                    <div class="d-flex flex-column gap-1">
                        @foreach (var step in flowSteps)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @StatusBadge(step)" style="min-width:130px;text-align:center;">
                                    @if (step == Model.Status) { <i class="bi bi-caret-right-fill me-1"></i> }
                                    @StatusLabel(step)
                                </span>
                                @if (step != "Delivered")
                                { <i class="bi bi-arrow-down text-muted" style="font-size:.65rem;"></i> }
                            </div>
                        }
                    </div>
                    <div class="mt-2 pt-2 border-top">
                        <span class="badge bg-danger">Failed</span>
                        <span class="text-muted small ms-1">— retry allowed</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>