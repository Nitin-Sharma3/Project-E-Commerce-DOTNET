@using CustomerDashboard.DTOs
@model List<AddressDto>

<div class="container py-5">

    <!-- HEADER -->
    <div class="mb-5">
        <h2 class="fw-bold">My Addresses</h2>
        <p class="text-muted">Manage your saved delivery locations</p>
    </div>

    <!-- GRID -->
    <div class="row g-4">

        <!-- ADD NEW CARD -->
        <div class="col-md-4">
            <div class="cura-card add-card" id="addAddressBtn">

                <div class="add-inner">
                    <div class="circle">
                        <i data-lucide="plus"></i>
                    </div>
                    <p>Add New Address</p>
                </div>

            </div>
        </div>

        <!-- ADDRESS CARDS -->
        @foreach (var item in Model)
        {
            <div class="card-top">

                <div class="d-flex flex-column gap-1">

                    @if (item.IsPrimary)
                    {
                        <span class="primary-label">PRIMARY</span>
                    }

                   <span class="address-type">

    @if(item.Type == 1)
    {
        <i data-lucide="home"></i> <span>Home</span>
    }
    else if(item.Type == 2)
    {
        <i data-lucide="briefcase"></i> <span>Office</span>
    }
    else
    {
        <i data-lucide="map-pin"></i> <span>@item.Label</span>
    }

</span>

                </div>

                <a href="/Address/Edit/@item.Id" class="icon-btn">
                    <i data-lucide="pencil"></i>
                </a>

            </div>
        }

    </div>

    <!-- FORM -->
    <div id="addressForm" class="cura-form mt-5 d-none">

        <form method="post" asp-action="Save" asp-controller="Address">

            <input type="hidden" name="Id" value="0" />

            <div class="row g-3">

                <div class="col-md-6">
                    <input name="FullName" placeholder="Full Name" required />
                </div>

                <div class="col-md-6">
                    <input name="PhoneNumber" placeholder="Phone Number" required />
                </div>

                <div class="col-md-6">
                    <input name="AddressLine1" placeholder="Address Line 1" required />
                </div>

                <div class="col-md-6">
                    <input name="AddressLine2" placeholder="Address Line 2" />
                </div>

                <div class="col-md-4">
                    <input id="pincode" name="PostalCode" placeholder="Pincode" required />
                </div>

                <div class="col-md-4">
                    <input id="city" name="City" placeholder="City" />
                </div>

                <div class="col-md-4">
                    <input id="state" name="State" placeholder="State" />
                </div>

                <div class="col-md-6">
                   <select name="Type">
    <option value="1" selected="@(ViewBag.EditData?.Type == 1)">Home</option>
    <option value="2" selected="@(ViewBag.EditData?.Type == 2)">Office</option>
    <option value="3" selected="@(ViewBag.EditData?.Type == 3)">Other</option>
</select>

<input name="Label" value="@ViewBag.EditData?.Label" />
                </div>
                <input name="Label" placeholder="Label (e.g. Hostel, PG, Home)" />
                <div class="col-md-6 d-flex align-items-center">
                    <input type="checkbox" name="IsPrimary" class="me-2" />
                    <label>Set as Primary</label>
                </div>

            </div>

            <button type="submit" class="btn-primary mt-4">Save Address</button>

        </form>
    </div>

</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        lucide.createIcons();

        const form = document.getElementById("addressForm");

        // Auto open if editing
        const isEdit = '@(ViewBag.EditData != null)' === 'True';

        if (isEdit) {
            form.classList.remove("d-none");
        }

        document.getElementById("addAddressBtn")
            .addEventListener("click", function () {
                form.classList.toggle("d-none");
            });
    });
</script>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();
</script>
<script>
    function toggleForm() {
        const form = document.getElementById("addressForm");

        if (!form) {
            console.log("Form not found ");
            return;
        }

        form.classList.toggle("d-none");
    }
</script>
<script>
    const pincodeInput = document.getElementById("pincode");

    pincodeInput.addEventListener("input", function () {
        const pin = this.value;

        console.log("Typing:", pin);

        if (pin.length === 6) {

            fetch(`https://api.postalpincode.in/pincode/${pin}`)
                .then(res => res.json())
                .then(data => {
                    console.log("API:", data);

                    if (data[0].Status === "Success") {
                        const post = data[0].PostOffice[0];

                        document.getElementById("city").value = post.District;
                        document.getElementById("state").value = post.State;
                    } else {
                        document.getElementById("city").value = "";
                        document.getElementById("state").value = "";
                    }
                })
                .catch(err => console.error(err));
        }
    });
</script>