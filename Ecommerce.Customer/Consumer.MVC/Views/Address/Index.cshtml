@using Consumer.MVC.ViewModel
@model List<AddressViewModel>

<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700&family=Plus+Jakarta+Sans:wght@400;500&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>

<style>
    :root {
        --surface: #f9f9f9;
        --surface-low: #f2f4f4;
        --surface-high: #e4e9ea;
        --white: #ffffff;
        --text: #2d3435;
        --text-soft: #5a6061;
        --primary: #5f5e5e;
        --primary-dim: #535252;
        --gold: #D4AF37;
    }

    body {
        background: var(--surface);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .add-card {
        background: var(--surface-low);
        border: 2px dashed rgba(173,179,180,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: 0.3s;
    }

        .add-card:hover {
            background: var(--surface-high);
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(45,52,53,0.06);
        }

    /* center everything nicely */
    .add-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    /* circle icon */
    .add-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

        /* icon size */
        .add-circle i {
            width: 28px;
            height: 28px;
            color: var(--primary);
        }
    h1 {
        font-family: 'Manrope';
        font-size: 3rem;
    }

    .subtext {
        color: var(--text-soft);
    }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    /* CARD */
    .card {
        background: var(--white);
        padding: 2rem;
        border-radius: 1.5rem;
        height: 260px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(45,52,53,0.06);
        }

    .primary-card {
        border: 2px solid var(--gold);
    }

    .secondary-card {
        border: 1.5px solid #212121;
    }

    .top-row {
        display: flex;
        justify-content: space-between;
    }

    .title-group {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .label {
        font-family: 'Manrope';
        font-weight: 600;
        font-size: 13px;
    }

    .type {
        font-size: 12px;
        color: var(--text-soft);
    }

    .primary-badge {
        background: var(--gold);
        color: white;
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 999px;
    }

    .name {
        font-family: 'Manrope';
        font-weight: 600;
    }

    .address {
        color: var(--text-soft);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        overflow: hidden;
    }

    .footer {
        display: flex;
        justify-content: space-between;
    }

    .remove {
        color: red;
        cursor: pointer;
    }

    /* ADD CARD */
    .add-card {
        background: var(--surface-low);
        border: 2px dashed rgba(173,179,180,0.4);
        text-align: center;
        cursor: pointer;
    }

    /* FORM */
    .form-box {
        margin-top: 4rem;
        padding: 3rem;
        background: var(--white);
        border-radius: 1.5rem;
    }

    .form-section {
        margin-top: 2rem;
    }

    .form-row {
        display: flex;
        gap: 1rem;
    }

    input, select {
        width: 100%;
        padding: 14px;
        border-radius: 0.75rem;
        border: none;
        background: var(--surface-low);
    }

        input:focus {
            outline: none;
            background: var(--surface-high);
        }

    .checkbox {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 1rem;
    }

        .checkbox input {
            width: 16px;
            height: 16px;
        }

    /* BUTTONS */
    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-dim));
        color: white;
        padding: 12px 24px;
        border-radius: 999px;
        border: none;
    }

    .btn-secondary {
        background: var(--surface-high);
        padding: 12px 24px;
        border-radius: 999px;
        border: none;
    }

    .form-actions {
        margin-top: 2rem;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }

    .hidden {
        display: none;
    }

    .privacy {
        display: flex;
        align-items: flex-start; /* aligns icon with top of text */
        gap: 12px; /* space between icon and text */
    }

    .icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .icon i {
            width: 24px;
            height: 24px;
        }

    .text h3 {
        margin: 0;
        font-size: 16px;
    }

    .subtext {
        margin: 4px 0 0;
        font-size: 14px;
        color: #666;
    }

    .section-title {
        font-family: 'Manrope';
        font-size: 16px;
        margin-bottom: 1rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 100%;
    }

        .input-group label {
            font-size: 13px;
            color: var(--text-soft);
        }

    input, select {
        width: 100%;
        padding: 14px;
        border-radius: 0.75rem;
        border: 1px solid transparent;
        background: var(--surface-low);
        transition: 0.2s;
    }

        input:focus, select:focus {
            outline: none;
            background: var(--white);
            border: 1px solid var(--primary);
            box-shadow: 0 0 0 3px rgba(95,94,94,0.08);
        }
    .form-box {
        margin-top: 4rem;
        padding: 3rem;
        background: var(--white);
        border-radius: 1.5rem;
        animation: fadeSlide 0.3s ease;
    }

    @@keyframes fadeSlide {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<h1>My Addresses</h1>
<h5>Manage your saved delivery locations for faster checkout experience.</h5>

<div class="grid">
    <!-- ADD CARD --> <div class="card add-card" onclick="openForm()"> <div class="add-circle"> <i data-lucide="plus"></i> </div> <h3>Add New Address</h3> <p class="subtext">Create a new shipping destination</p> </div>

    @foreach (var item in Model.OrderByDescending(x => x.IsPrimary))
    {
        <div class="card @(item.IsPrimary ? "primary-card" : "secondary-card")">

            <div class="top-row">
                <div class="title-group">
                    <span class="label">@item.Label</span>
                    <span class="type">@item.Type</span>

                    @if (item.IsPrimary)
                    {
                        <span class="primary-badge">PRIMARY</span>
                    }
                </div>

                <i data-lucide="pencil"
                   onclick='editAddress(@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(item)))'></i>
            </div>

            <div>
                <div class="name">@item.FullName</div>
                <div class="address">
                    @item.AddressLine1, @item.City - @item.PostalCode
                </div>
            </div>

            <div class="footer"> <span><i data-lucide="phone"></i> @item.PhoneNumber</span>
                <span class="remove" onclick="deleteAddress(@item.Id)">Remove</span>
            </div>

        </div>
    }

</div>

<!-- FORM -->
<div id="formBox" class="form-box hidden">

    <h2 id="formTitle">Add Address</h2>

    <input type="hidden" id="Id" />

    <!-- PERSONAL -->
    <div class="form-section">
        <h4 class="section-title">Contact Details</h4>

        <div class="form-row">
            <div class="input-group">
                <label>Full Name</label>
                <input id="FullName" placeholder="Enter full name" />
            </div>

            <div class="input-group">
                <label>Phone Number</label>
                <input id="PhoneNumber" value="+91" maxlength="13" />
            </div>
        </div>
    </div>

    <!-- ADDRESS -->
    <div class="form-section">
        <h4 class="section-title">Address</h4>

        <div class="input-group">
            <label>Address Line 1</label>
            <input id="AddressLine1" placeholder="House / Flat / Street" />
        </div>

        <div class="input-group">
            <label>Address Line 2</label>
            <input id="AddressLine2" placeholder="Landmark (optional)" />
        </div>

        <div class="form-row">
            <div class="input-group">
                <label>Postal Code</label>
                <input id="PostalCode" placeholder="6-digit PIN" />
            </div>

            <div class="input-group">
                <label>City</label>
                <input id="City" placeholder="City" />
            </div>

            <div class="input-group">
                <label>State</label>
                <input id="State" placeholder="State" />
            </div>
        </div>
    </div>

    <!-- TYPE -->
    <div class="form-section">
        <h4 class="section-title">Address Type</h4>

        <div class="form-row">
            <div class="input-group">
                <label>Type</label>
                <select id="Type">
                    <option value="1">Home</option>
                    <option value="2">Office</option>
                    <option value="3">Other</option>
                </select>
            </div>

            <div class="input-group">
                <label>Label</label>
                <input id="Label" placeholder="e.g. Mom's House" />
            </div>
        </div>

        <label class="checkbox">
            <input type="checkbox" id="IsPrimary" />
            <span>Set as Primary Address</span>
        </label>
    </div>

    <!-- ACTIONS -->
    <div class="form-actions">
        <button class="btn-secondary" onclick="closeForm()">Cancel</button>
        <button class="btn-primary" onclick="saveAddress()">Save Address</button>
    </div>

</div>
<br />
<div class="privacy">
    <div class="icon">
        <i data-lucide="shield"></i>
    </div>
    <div class="text">
        <h3>Your Privacy Matters</h3>
        <p class="subtext">
            Every address is securely encrypted and used only for delivery fulfillment.
            Your data remains protected across our logistics systems.
        </p>
    </div>
</div>
<script>
    lucide.createIcons();

    // function openForm() {
    //     formBox.classList.remove("hidden");
    // }
        function openForm(isEdit = false) {
        formBox.classList.remove("hidden");

        document.getElementById("formTitle").innerText =
            isEdit ? "Edit Address" : "Add Address";
    }

    function editAddress(data) {
        openForm(true);

        Id.value = data.Id;
        FullName.value = data.FullName;
        PhoneNumber.value = data.PhoneNumber || "+91";
        AddressLine1.value = data.AddressLine1;
        AddressLine2.value = data.AddressLine2;
        PostalCode.value = data.PostalCode;
        City.value = data.City;
        State.value = data.State;
        Label.value = data.Label;
        IsPrimary.checked = data.IsPrimary;

        Type.value = data.Type === "Office" ? 2 : data.Type === "Other" ? 3 : 1;
    }
    async function deleteAddress(id) {

    const confirmDelete = confirm("Are you sure you want to remove this address?");

    if (!confirmDelete) return;

    await fetch(`https://localhost:7064/api/Address/${id}`, {
        method: "DELETE"
    });

    location.reload();
}
    function closeForm() {
        formBox.classList.add("hidden");
    }

    // function editAddress(data) {
    //     openForm();

    //     Id.value = data.Id;
    //     FullName.value = data.FullName;
    //     PhoneNumber.value = data.PhoneNumber || "+91";
    //     AddressLine1.value = data.AddressLine1;
    //     AddressLine2.value = data.AddressLine2;
    //     PostalCode.value = data.PostalCode;
    //     City.value = data.City;
    //     State.value = data.State;
    //     Label.value = data.Label;
    //     IsPrimary.checked = data.IsPrimary;

    //     Type.value = data.Type === "Office" ? 2 : data.Type === "Other" ? 3 : 1;
    // }

    async function saveAddress() {

        if (!/^\+91[0-9]{10}$/.test(PhoneNumber.value)) {
            alert("Invalid phone number");
            return;
        }

        const payload = {
            FullName: FullName.value,
            PhoneNumber: PhoneNumber.value,
            AddressLine1: AddressLine1.value,
            AddressLine2: AddressLine2.value,
            PostalCode: PostalCode.value,
            City: City.value,
            State: State.value,
            Country: "India",
            Type: parseInt(Type.value),
            Label: Label.value,
            IsPrimary: IsPrimary.checked
        };

        const url = Id.value
            ? `https://localhost:7064/api/Address/${Id.value}`
            : `https://localhost:7064/api/Address`;

        const method = Id.value ? "PUT" : "POST";

        await fetch(url, {
            method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        location.reload();
    }
        document.addEventListener("DOMContentLoaded", function () {

        const postalInput = document.getElementById("PostalCode");
        const cityInput = document.getElementById("City");
        const stateInput = document.getElementById("State");

        postalInput.addEventListener("input", async function () {

            const pin = this.value.trim();

            // Only trigger when exactly 6 digits
            if (/^[0-9]{6}$/.test(pin)) {

                try {
                    const res = await fetch(`https://api.postalpincode.in/pincode/${pin}`);
                    const data = await res.json();

                    if (data[0].Status === "Success") {

                        const postOffice = data[0].PostOffice[0];

                        cityInput.value = postOffice.District;
                        stateInput.value = postOffice.State;

                    } else {
                        cityInput.value = "";
                        stateInput.value = "";
                        alert("Invalid Postal Code");
                    }

                } catch (error) {
                    console.error("Error fetching postal data:", error);
                }
            }
        });
    });
    /* PHONE CONTROL */
    document.addEventListener("DOMContentLoaded", function () {

        const phoneInput = document.getElementById("PhoneNumber");

        phoneInput.addEventListener("keydown", function (e) {
            if (this.selectionStart <= 3 &&
                (e.key === "Backspace" || e.key === "Delete")) {
                e.preventDefault();
            }
        });

        phoneInput.addEventListener("input", function () {

            let value = this.value;

            if (!value.startsWith("+91")) {
                value = "+91" + value.replace(/\D/g, "");
            }

            let digits = value.substring(3).replace(/\D/g, "");
            digits = digits.substring(0, 10);

            this.value = "+91" + digits;
        });
    });
</script>