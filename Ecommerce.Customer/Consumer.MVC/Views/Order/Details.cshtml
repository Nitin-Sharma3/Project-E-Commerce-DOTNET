@model Consumer.MVC.ViewModel.OrderDetailViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container">
        <div class="row">
            <div>
                <div class="breadcrumb">
                    <a href="/">Home</a> <span>›</span>
                    <a href="@Url.Action("Index", "Order")">Orders</a> <span>›</span>
                    <span>#@Model.OrderNumber</span>
                </div>
                <h1>Order <span>#@Model.OrderNumber</span></h1>
                <div style="margin-top:8px;font-size:0.8rem;color:#9E9E9E">
                    Placed on @Model.PlacedAt.ToString("dd MMM yyyy 'at' hh:mm tt")
                </div>
            </div>
            <span class="status-badge" id="statusBadge">@Model.Status</span>
        </div>
    </div>
</div>

<div class="container" style="padding-bottom:60px">
    <div class="detail-grid">

        <!-- Left Column -->
        <div>
            <!-- Tracking -->
            @if (!string.IsNullOrEmpty(Model.TrackingNumber))
            {
                <div class="card">
                    <div class="card-body">
                        <div class="tracking-box">
                            <div class="tracking-icon">🚚</div>
                            <div>
                                <div class="tracking-label">TRACKING NUMBER</div>
                                <div class="tracking-num">@Model.TrackingNumber</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Timeline -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    </div>
                    <h3>Order Timeline</h3>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        @foreach (var evt in Model.Timeline)
                        {
                            <div class="tl-item">
                                <div class="tl-dot-wrap">
                                    <div class="tl-dot @(evt.IsCompleted ? "done" : evt.IsCurrent ? "current" : "pending")">
                                        @if (evt.IsCompleted)
                                        {
                                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                                        }
                                        else if (evt.IsCurrent)
                                        {
                                            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4" /></svg>
                                        }
                                        else
                                        {
                                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4" stroke-width="2" /></svg>
                                        }
                                    </div>
                                    <div class="tl-line @(evt.IsCompleted ? "done-line" : "")"></div>
                                </div>
                                <div class="tl-content">
                                    <div class="tl-status" style="color:@(evt.IsCurrent ? "var(--tertiary)" : evt.IsCompleted ? "var(--success)" : "var(--text-muted)")">
                                        @evt.Status
                                    </div>
                                    <div class="tl-desc">@evt.Description</div>
                                    @if (evt.Timestamp != default)
                                    {
                                        <div class="tl-time">@evt.Timestamp.ToString("dd MMM yyyy, hh:mm tt")</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Items -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                    </div>
                    <h3>Order Items (@Model.Items.Count)</h3>
                </div>
                <div class="card-body">
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item">
                            <img class="oi-img" src="@item.ProductImage" alt="@item.ProductName" onerror="this.src='/images/placeholder.webp'" />
                            <div class="oi-info">
                                <div class="oi-cat">@item.Category</div>
                                <div class="oi-name" title="@item.ProductName">@item.ProductName</div>
                                <div class="oi-sku">SKU: @item.Sku</div>
                            </div>
                            <div class="oi-price">
                                <div class="oi-unit">₹@item.UnitPrice.ToString("N0") × @item.Quantity</div>
                                <div class="oi-total">₹@item.LineTotal.ToString("N0")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div>
            <!-- Actions -->
            <div class="card">
                <div class="card-header"><h3>Actions</h3></div>
                <div class="card-body">
                    <a href="/Products" class="action-btn btn-primary">Continue Shopping</a>
                    <a href="@Url.Action("Index", "Order")" class="action-btn btn-outline">Back to Orders</a>
                    @if (Model.CanCancel)
                    {
                        <form asp-action="Cancel" asp-controller="Order" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="action-btn btn-danger"
                                    onclick="return confirm('Cancel this order?')">
                                Cancel Order
                            </button>
                        </form>
                    }
                </div>
            </div>

            <!-- Price Summary -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                    </div>
                    <h3>Price Summary</h3>
                </div>
                <div class="card-body">
                    <div class="sum-row"><label>Subtotal</label><span class="v">₹@Model.Subtotal.ToString("N0")</span></div>
                    @if (Model.Discount > 0)
                    {
                        <div class="sum-row" style="color:var(--success)"><label>Discount</label><span class="v">-₹@Model.Discount.ToString("N0")</span></div>
                    }
                    <div class="sum-row"><label>Shipping</label><span class="v">@(Model.ShippingCost == 0 ? "FREE" : "₹" + Model.ShippingCost.ToString("N0"))</span></div>
                    <div class="sum-row"><label>GST (18%)</label><span class="v">₹@Model.Tax.ToString("N0")</span></div>
                    <div class="sum-row grand"><label>Total</label><span class="v">₹@Model.Total.ToString("N0")</span></div>
                </div>
            </div>

            <!-- Payment -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                    </div>
                    <h3>Payment</h3>
                </div>
                <div class="card-body">
                    <div style="font-size:.88rem; margin-bottom:6px">
                        <span style="color:var(--text-muted)">Method:</span>
                        <strong style="margin-left:8px">@Model.PaymentMethod</strong>
                    </div>
                    <div style="font-size:.88rem">
                        <span style="color:var(--text-muted)">Status:</span>
                        <strong style="margin-left:8px;color:var(--success)">@Model.PaymentStatus</strong>
                    </div>
                </div>
            </div>

            <!-- Shipping Address -->
            @if (Model.ShippingAddress != null)
            {
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        </div>
                        <h3>Delivery Address</h3>
                    </div>
                    <div class="card-body">
                        <div class="addr-name">@Model.ShippingAddress.FullName</div>
                        <div class="addr-line">
                            @Model.ShippingAddress.AddressLine1<br />
                            @if (!string.IsNullOrEmpty(Model.ShippingAddress.AddressLine2))
                            {
                                @Model.ShippingAddress.AddressLine2
                                <br />
     }
                            @Model.ShippingAddress.City, @Model.ShippingAddress.State @Model.ShippingAddress.PostalCode<br />
                            @Model.ShippingAddress.Country
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ShippingAddress.PhoneNumber))
                        {
                            <div style="margin-top:8px;font-size:.82rem;color:var(--text-muted)">
                                📞 @Model.ShippingAddress.PhoneNumber
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Colour-code the status badge
    const statusColors = {
        pending: '#F59E0B', confirmed: '#3B82F6', processing: '#8B5CF6',
        shipped: '#06B6D4', delivered: '#10B981', cancelled: '#EF4444', refunded: '#6B7280'
    };
    const badge = document.getElementById('statusBadge');
    const key = badge.textContent.trim().toLowerCase();
    if (statusColors[key]) {
        badge.style.color = statusColors[key];
        badge.style.borderColor = statusColors[key];
        badge.style.background = statusColors[key] + '18';
    }
</script>
