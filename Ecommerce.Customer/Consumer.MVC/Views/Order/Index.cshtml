
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="page-header">
    <div class="container">
        <div>
            <h1>My <span>Orders</span></h1>
            <div style="margin-top:8px;font-size:0.82rem;color:#9E9E9E">
                Track, manage and review your purchases
            </div>
        </div>
        <a href="@Url.Action("Index", "Cart")" class="cta-btn">View Cart →</a>
    </div>
</div>

<div class="container" style="padding-bottom:60px">

    @if (Model.Orders.Any())
    {
        <!-- Stats -->
        <div class="stats-bar">
            <div class="stat-card">
                <div class="stat-label">Total Orders</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Delivered</div>
                @* <div class="stat-value gold">@Model.Orders.Count(o => o.Status == "Delivered")</div> *@
            </div>
            <div class="stat-card">
                <div class="stat-label">In Progress</div>
                @* <div class="stat-value">@Model.Orders.Count(o => o.Status is "Processing" or "Shipped" or "Confirmed")</div> *@
            </div>
            <div class="stat-card">
                <div class="stat-label">Cancelled</div>
                @* <div class="stat-value" style="color:var(--danger)">@Model.Orders.Count(o => o.Status == "Cancelled")</div> *@
            </div>
        </div>
    }

    <!-- Filter tabs -->
    <div class="filter-tabs">
        @foreach (var tab in new[] { ("", "All Orders"), ("Pending", "Pending"), ("Processing", "Processing"), ("Shipped", "Shipped"), ("Delivered", "Delivered"), ("Cancelled", "Cancelled") })
        {
            <a href="@Url.Action("Index", "Order", new { status = tab.Item1 })"
               class="filter-tab @(Model.StatusFilter == tab.Item1 ? "active" : "")">
                @tab.Item2
            </a>
        }
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="empty-orders">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            <h3>No orders yet</h3>
            <p>Start shopping for the latest laptops and mobile accessories.</p>
            <a href="/Products" class="cta-btn">Browse Products</a>
        </div>
    }
    else
    {
        @foreach (var order in Model.Orders)
        {
            <a class="order-card" href="@Url.Action("Detail", "Order", new { id = order.Id })">
                <div class="order-card-body">
                    <img class="order-thumb" src="@order.ThumbnailUrl" alt="@order.FirstProductName" onerror="this.src='/images/placeholder.webp'" />

                    <div class="order-info">
                        <div class="order-number">Order #@order.OrderNumber</div>
                        <div class="order-products">
                            @order.FirstProductName @(order.ItemCount > 1 ? $"+ {order.ItemCount - 1} more item(s)" : "")
                        </div>
                        <div class="order-date">Placed on @order.PlacedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                    </div>

                    <div class="order-meta">
                        <div>
                            <span class="status-pill" style="background:@order.StatusColor20;color:@order.StatusColor">
                                @order.Status
                            </span>
                        </div>
                        <div class="order-total">₹@order.Total.ToString("N0")</div>
                        <div class="order-items-count">@order.ItemCount item@(order.ItemCount != 1 ? "s" : "")</div>
                    </div>
                </div>
                <div class="order-card-footer">
                    <span class="payment-tag">
                        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:4px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        @order.ItemCount item@(order.ItemCount != 1 ? "s" : "")
                    </span>
                    <span class="view-detail-link">View Details →</span>
                </div>
            </a>
        }
    }
</div>

<script>
    // Add translucent status bg colors
    document.querySelectorAll('.status-pill').forEach(el => {
        const color = el.style.color;
        el.style.background = color + '20';
    });
</script>
