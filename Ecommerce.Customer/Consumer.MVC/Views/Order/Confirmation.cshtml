@model Consumer.MVC.ViewModel.OrderDetailViewModel
@{
    ViewData["Title"] = "Order Confirmed!";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="confetti-header">
    <div class="check-circle">
        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
        </svg>
    </div>
    <h1>Order Placed! </h1>
    <p>Thank you! Your order has been confirmed and is being processed.</p>
    <div class="order-num-badge">Order #@Model.OrderNumber</div>
</div>

<div class="container" style="padding-bottom:60px">
    <div class="main-card">

        <!-- Order Info -->
        <div class="card-section">
            <div class="section-label">Order Details</div>
            <div class="info-row"><label>Order Number</label><span class="v">#@Model.OrderNumber</span></div>
            <div class="info-row"><label>Date</label><span class="v">@Model.PlacedAt.ToString("dd MMM yyyy, hh:mm tt")</span></div>
            <div class="info-row"><label>Payment</label><span class="v">@Model.PaymentMethod</span></div>
            <div class="info-row"><label>Status</label><span class="v" style="color:var(--success)">@Model.Status</span></div>
        </div>

        <!-- Items -->
        <div class="card-section">
            <div class="section-label">Items (@Model.Items.Count)</div>
            @foreach (var item in Model.Items)
            {
                <div class="order-item">
                    <img class="item-img" src="@item.ProductImage" alt="@item.ProductName" onerror="this.src='/images/placeholder.webp'" />
                    <div style="flex:1;min-width:0">
                        <div class="item-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@item.ProductName</div>
                        <div class="item-sub">Qty: @item.Quantity · SKU: @item.Sku</div>
                    </div>
                    <div class="item-price">₹@item.LineTotal.ToString("N0")</div>
                </div>
            }
        </div>

        <!-- Totals -->
        <div class="card-section">
            <div class="section-label">Payment Summary</div>
            <div class="totals-grid">
                <div class="total-row"><label>Subtotal</label><span class="v">₹@Model.Subtotal.ToString("N0")</span></div>
                @if (Model.Discount > 0)
                {
                    <div class="total-row" style="color:var(--success)"><label>Discount</label><span class="v">-₹@Model.Discount.ToString("N0")</span></div>
                }
                <div class="total-row"><label>Shipping</label><span class="v">@(Model.ShippingCost == 0 ? "FREE" : "₹" + Model.ShippingCost.ToString("N0"))</span></div>
                <div class="total-row"><label>GST (18%)</label><span class="v">₹@Model.Tax.ToString("N0")</span></div>
                <div class="total-row grand"><label>Total Paid</label><span class="v">₹@Model.Total.ToString("N0")</span></div>
            </div>
        </div>

        <!-- Shipping Address -->
        @if (Model.ShippingAddress != null)
        {
            <div class="card-section">
                <div class="section-label">Delivery To</div>
                <div style="font-weight:700;margin-bottom:4px">@Model.ShippingAddress.FullName</div>
                <div style="font-size:.85rem;color:var(--text-muted);line-height:1.7">
                    @Model.ShippingAddress.AddressLine1<br />
                    @Model.ShippingAddress.City, @Model.ShippingAddress.State @Model.ShippingAddress.PostalCode<br />
                    @Model.ShippingAddress.Country
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="action-row">
            <a href="@Url.Action("Detail", "Order", new { id = Model.Id })" class="btn btn-gold">Track Order →</a>
            <a href="/Products" class="btn btn-outline">Continue Shopping</a>
        </div>
    </div>
</div>
