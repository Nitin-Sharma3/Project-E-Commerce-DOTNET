@model Consumer.MVC.ViewModel.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />



<div class="page-header">
    <div class="container">
        <div>
            <h1>Shopping <span>Cart</span></h1>
            <div class="breadcrumb" style="margin-top:8px">
                <a href="/">Home</a> <span>›</span> <span>Cart</span>
            </div>
        </div>
        @if (Model.Items.Any())
        {
            <span class="badge badge-gold">@Model.ItemCount item@(Model.ItemCount != 1 ? "s" : "")</span>
        }
    </div>
</div>

<div class="container" style="padding-bottom:60px">

    @if (TempData["Error"] != null)
    {
        <div style="background:#FEF2F2;border:1px solid #FECACA;color:#DC2626;padding:14px 20px;border-radius:12px;margin-bottom:24px;font-size:.88rem;font-weight:600">
            ⚠ @TempData["Error"]
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="cart-panel">
            <div class="empty-cart">
                <svg fill="none" width="100" height="100" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m5-9v9m4-9v9m5-4H9" />
                </svg>
                <h3>Your cart is empty</h3>
                <p>Looks like you haven't added anything yet. Explore our latest laptops and accessories.</p>
                <a href="/Products" class="checkout-btn" style="display:inline-block;width:auto;padding:14px 36px">Start Shopping</a>
            </div>
        </div>
    }
    else
    {
        <div class="cart-grid">
            <!-- Items -->
            <div>
                <div class="cart-panel">
                    <div class="cart-panel-header">
                        <div style="display:flex;align-items:center;gap:12px">
                            <h2>Cart Items</h2>
                            <span class="badge">@Model.Items.Count</span>
                        </div>
                        <form asp-action="Clear" asp-controller="Cart" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="clear-btn" onclick="return confirm('Clear all items?')">Clear all</button>
                        </form>
                    </div>

                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item" id="item-@item.ProductId">
                            <img class="item-img" src="@item.ProductImage" alt="@item.ProductName" onerror="this.src='/images/placeholder.webp'" />

                            <div class="item-info">
                                <div class="item-category">@item.Category</div>
                                <div class="item-name" title="@item.ProductName">@item.ProductName</div>
                                <div class="item-sku">SKU: @item.Sku</div>
                                <div class="item-price-row">
                                    <span class="item-price">₹@item.DiscountedPrice.ToString("N0")</span>
                                    @if (item.UnitPrice > item.DiscountedPrice)
                                    {
                                        <span class="item-original">₹@item.UnitPrice.ToString("N0")</span>
                                        var savePct = (int)Math.Round((1 - item.DiscountedPrice / item.UnitPrice) * 100);
                                        <span class="item-discount">-@savePct%</span>
                                    }
                                </div>
                                @if (!item.InStock)
                                {
                                    <span class="out-of-stock" style="margin-top:6px;display:inline-block">Out of stock</span>
                                }
                            </div>

                            <div class="item-actions">
                                <div class="qty-control">
                                    <button class="qty-btn" onclick="changeQty(@item.ProductId, -1)">−</button>
                                    <input class="qty-input" id="qty-@item.ProductId" type="number"
                                           value="@item.Quantity" min="1" max="@item.MaxQuantity"
                                           onchange="updateQty(@item.ProductId, this.value)" />
                                    <button class="qty-btn" onclick="changeQty(@item.ProductId, 1)">+</button>
                                </div>
                                <div class="item-line-total" id="line-@item.ProductId">₹@item.LineTotal.ToString("N0")</div>
                                <button class="remove-btn" onclick="removeItem(@item.ProductId)">
                                    <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                                    Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Summary -->
            <div>
                <div class="summary-card">
                    <div class="summary-header"><h3>Order Summary</h3></div>
                    <div class="summary-body">
                        <div class="coupon-row">
                            <div class="coupon-input-wrap">
                                <input class="coupon-input" id="couponInput" type="text" placeholder="Coupon / promo code" />
                                <button class="coupon-btn" onclick="applyCoupon()">Apply</button>
                            </div>
                        </div>

                        <div class="summary-row">
                            <label>Subtotal</label>
                            <span class="val" id="sumSubtotal">₹@Model.Subtotal.ToString("N0")</span>
                        </div>
                        @if (Model.Discount > 0)
                        {
                            <div class="summary-row" style="color:var(--success)">
                                <label>Discount</label>
                                <span class="val">-₹@Model.Discount.ToString("N0")</span>
                            </div>
                        }
                        <div class="summary-row">
                            <label>Shipping</label>
                            <span class="val" id="sumShipping">@(Model.Shipping == 0 ? "FREE" : "₹" + Model.Shipping.ToString("N0"))</span>
                        </div>
                        <div class="summary-row">
                            <label>GST (18%)</label>
                            <span class="val" id="sumTax">₹@Model.Tax.ToString("N0")</span>
                        </div>
                        <div class="summary-row total">
                            <label>Total</label>
                            <span class="val" id="sumTotal">₹@Model.Total.ToString("N0")</span>
                        </div>
                    </div>

                    @if (Model.Discount > 0)
                    {
                        <div class="savings-row">
                            <span>🎉 You save</span>
                            <span>₹@Model.Discount.ToString("N0")</span>
                        </div>
                    }

                    <div style="padding:20px 24px 12px">
                        <a href="@Url.Action("Checkout", "Order")" class="checkout-btn">Proceed to Checkout →</a>
                        <a href="/Products" class="continue-btn">Continue Shopping</a>
                    </div>

                    <div class="trust-badges">
                        <div class="trust-badge">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                            Secure
                        </div>
                        <div class="trust-badge">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                            All Cards
                        </div>
                        <div class="trust-badge">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                            Returns
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="toast-container" id="toastContainer"></div>

<script>
    const antiForgeryToken = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)?.[1] ?? '';

    function showToast(msg, type = 'success') {
        const c = document.getElementById('toastContainer');
        const t = document.createElement('div');
        t.className = `toast ${type}`;
        t.innerHTML = `<span>${type === 'success' ? '✓' : '✕'}</span>${msg}`;
        c.appendChild(t);
        setTimeout(() => t.remove(), 3500);
    }

    function changeQty(productId, delta) {
        const input = document.getElementById(`qty-${productId}`);
        const newVal = Math.max(1, Math.min(parseInt(input.max) || 99, parseInt(input.value) + delta));
        input.value = newVal;
        updateQty(productId, newVal);
    }

    async function updateQty(productId, quantity) {
        quantity = parseInt(quantity);
        if (isNaN(quantity) || quantity < 1) return;

        const res = await fetch('/Cart/Update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
            body: JSON.stringify({ productId, quantity })
        });
        const data = await res.json();
        if (data.success) {
            if (data.lineTotal) document.getElementById(`line-${productId}`).textContent = data.lineTotal;
            if (data.total) document.getElementById('sumTotal').textContent = data.total;
            if (data.subtotal) document.getElementById('sumSubtotal').textContent = data.subtotal;
            showToast('Cart updated');
        } else {
            showToast(data.message || 'Update failed', 'error');
        }
    }

    async function removeItem(productId) {
        const res = await fetch('/Cart/Remove/' + productId, {
            method: 'POST',
            headers: { 'RequestVerificationToken': antiForgeryToken }
        });
        const data = await res.json();
        if (data.success) {
            const el = document.getElementById(`item-${productId}`);
            el.style.transition = 'opacity .3s, transform .3s';
            el.style.opacity = '0'; el.style.transform = 'translateX(20px)';
            setTimeout(() => { el.remove(); location.reload(); }, 300);
        } else {
            showToast('Could not remove item', 'error');
        }
    }

    async function applyCoupon() {
        const code = document.getElementById('couponInput').value.trim();
        if (!code) return showToast('Enter a coupon code', 'error');
        showToast('Coupon applied! (demo)', 'success');
    }
</script>
