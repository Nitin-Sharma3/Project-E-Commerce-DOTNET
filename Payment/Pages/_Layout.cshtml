<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Razorpay Demo</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
