@page
@model RazorpayApi.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div style="text-align: center; padding: 40px 0;">
    <h1 style="font-size: 32px; margin-bottom: 16px;">Razorpay .NET 8 Demo</h1>
    <p style="font-size: 16px; color: #9ca3af; margin-bottom: 32px;">Test Razorpay payment integration — create an order, pay via checkout, and verify the signature.</p>
    <a href="/Payment" class="btn" style="display: inline-block; padding: 14px 28px; font-size: 16px;">
        Start Payment →
    </a>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; margin-top: 40px;">
    <div style="background: #0f172a; padding: 24px; border-radius: 12px; border: 1px solid #111827;">
        <div style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: linear-gradient(135deg, #7c3aed, #6366f1); border-radius: 8px; margin-bottom: 16px; font-size: 24px;">
            1️⃣
        </div>
        <h3 style="margin-bottom: 12px;">Create Order</h3>
        <p style="color: #9ca3af; font-size: 14px;">Server creates a Razorpay order and gets back an <code style="background: #020617; padding: 2px 6px; border-radius: 4px;">order_id</code>.</p>
    </div>
    <div style="background: #0f172a; padding: 24px; border-radius: 12px; border: 1px solid #111827;">
        <div style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: linear-gradient(135deg, #7c3aed, #6366f1); border-radius: 8px; margin-bottom: 16px; font-size: 24px;">
            2️⃣
        </div>
        <h3 style="margin-bottom: 12px;">Checkout</h3>
        <p style="color: #9ca3af; font-size: 14px;">Razorpay modal handles card / UPI / NetBanking securely.</p>
    </div>
    <div style="background: #0f172a; padding: 24px; border-radius: 12px; border: 1px solid #111827;">
        <div style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: linear-gradient(135deg, #7c3aed, #6366f1); border-radius: 8px; margin-bottom: 16px; font-size: 24px;">
            3️⃣
        </div>
        <h3 style="margin-bottom: 12px;">Verify</h3>
        <p style="color: #9ca3af; font-size: 14px;">Signature verified server-side to confirm payment is genuine.</p>
    </div>
</div>
