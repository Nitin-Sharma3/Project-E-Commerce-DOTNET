<!DOCTYPE html>

<html>
<head>

    <meta name="viewport" content="width=device-width" />
    <title>Seller Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #0d0d14;
            font-family: Segoe UI, sans-serif;
            color: white;
            margin: 0;
        }

        /* SIDEBAR */

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            padding: 22px;
            background: #151521;
            border-right: 1px solid rgba(255,255,255,0.06);
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            /* Collapsed sidebar */

            .sidebar.collapsed {
                width: 70px;
            }

        /* Sidebar header */

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
        }

            .sidebar-header h4 {
                margin: 0;
                font-weight: 600;
                color: #a5b4fc;
                transition: 0.3s;
            }

        /* Hide title when collapsed */

        .sidebar.collapsed h4 {
            display: none;
        }

        /* Sidebar links */

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            margin-bottom: 8px;
            text-decoration: none;
            color: #9ca3af;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

            .sidebar a:hover {
                background: #1f1f2e;
                color: white;
            }

            .sidebar a.active {
                background: #26263a;
                color: #a78bfa;
            }

        /* Hide link text when collapsed */

        .sidebar.collapsed a {
            justify-content: center;
            font-size: 18px;
        }

        /* MAIN CONTENT */

        .main {
            margin-left: 260px;
            padding: 30px;
            transition: 0.3s;
            background: transparent;
        }

            .main.full {
                margin-left: 90px;
            }

        /* TOPBAR */

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #181825;
            padding: 15px 20px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            margin-bottom: 25px;
        }

        /* Menu button */

        .menu-btn {
            font-size: 20px;
            cursor: pointer;
            color: #9ca3af;
        }

            .menu-btn:hover {
                color: white;
            }

    </style>

</head>

<body>

    <!-- SIDEBAR -->

    <div id="sidebar" class="sidebar">

        <div class="sidebar-header">

            <span class="menu-btn" onclick="toggleMenu()">☰</span>

            <h4>Seller Panel</h4>

        </div>

        <a href="/" class="active">📊 Dashboard</a> <a href="/Product/Add">➕ Add Product</a> <a href="/Product/Inventory">📦 My Inventory</a>

    </div>

    <!-- MAIN CONTENT -->

    <div id="main" class="main">

        <div class="topbar">

            <h5 class="mb-0">Seller Dashboard</h5>

        </div>

        @RenderBody()

    </div>

    <script>

        function toggleMenu(){

        document.getElementById("sidebar").classList.toggle("collapsed");
        document.getElementById("main").classList.toggle("full");

        }

    </script>

</body>

</html>
