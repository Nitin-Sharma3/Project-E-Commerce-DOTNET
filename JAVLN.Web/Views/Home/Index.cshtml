@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    <div class="container text-center hero-content">
        <span class="hero-tag">🚀 Next Generation Commerce</span>
        <h1 class="hero-title">Shop Smarter.<br><span class="gradient-text">Sell Faster.</span></h1>
        <p class="hero-sub">JAVLN connects buyers and sellers in a blazing-fast, secure marketplace experience.</p>
        <div class="hero-actions">
            <a asp-controller="Account" asp-action="Register" class="btn javln-btn-primary btn-lg">
                <i class="bi bi-person-plus"></i> Start Shopping
            </a>
            <a asp-controller="Account" asp-action="RegisterSeller" class="btn javln-btn-outline btn-lg">
                <i class="bi bi-shop"></i> Become a Seller
            </a>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">🔐</div>
                    <h3>Secure Auth</h3>
                    <p>OTP verification + JWT-powered sessions keep your account safe.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h3>Fast Checkout</h3>
                    <p>Streamlined buying experience from cart to confirmation in seconds.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">🏪</div>
                    <h3>Seller Tools</h3>
                    <p>Powerful dashboard for sellers to manage products and orders.</p>
                </div>
            </div>
        </div>
    </div>
</section>