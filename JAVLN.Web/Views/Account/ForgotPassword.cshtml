@model JAVLN.Web.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Reset Password</h2>
            <p>We'll send a reset token to your email</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-floating mb-4">
                <input asp-for="Email" class="form-control" placeholder="email" />
                <label asp-for="Email"><i class="bi bi-envelope"></i> Email Address</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn javln-btn-primary w-100 btn-lg">
                <i class="bi bi-send"></i> Send Reset Token
            </button>
        </form>

        <div class="auth-links">
            <a asp-action="Login">Back to Login</a>
        </div>
    </div>
</div>