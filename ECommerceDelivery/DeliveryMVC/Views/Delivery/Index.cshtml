@model List<DeliveryMVC.Models.DeliveryViewModel>
@{
    Layout = null;
    var statuses = new[] { "All", "Pending", "Packed", "Shipped", "OutForDelivery", "Delivered", "Failed" };
    string current = ViewBag.StatusFilter ?? "All";

    (string bg, string fg, string ring) StatusStyle(string s) => s switch {
        "Pending"        => ("#f1f5f9", "#64748b", "#e2e8f0"),
        "Packed"         => ("#eff6ff", "#2563eb", "#bfdbfe"),
        "Shipped"        => ("#eef2ff", "#4f46e5", "#c7d2fe"),
        "OutForDelivery" => ("#fffbeb", "#d97706", "#fde68a"),
        "Delivered"      => ("#f0fdf4", "#16a34a", "#bbf7d0"),
        "Failed"         => ("#fff1f2", "#e11d48", "#fecdd3"),
        _                => ("#f8fafc", "#64748b", "#e2e8f0")
    };
    string StatusIcon(string s) => s switch {
        "Pending"        => "bi-hourglass-split",
        "Packed"         => "bi-box-seam",
        "Shipped"        => "bi-truck",
        "OutForDelivery" => "bi-bicycle",
        "Delivered"      => "bi-check-circle-fill",
        "Failed"         => "bi-x-circle-fill",
        _                => "bi-circle"
    };
    string StatusLabel(string s) => s == "OutForDelivery" ? "Out for Delivery" : s;

    var counts = statuses.Skip(1).ToDictionary(
        s => s,
        s => Model.Count(d => d.Status == s)
    );
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>DeliveryOps — Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-w: 232px;
            --bg: #f8fafc;
            --surface: #ffffff;
            --border: #e2e8f0;
            --border-strong: #cbd5e1;
            --text: #0f172a;
            --muted: #64748b;
            --subtle: #94a3b8;
            --accent: #2563eb;
            --accent-light: #eff6ff;
            --accent-ring: #bfdbfe;
            --sidebar-bg: #0c111d;
            --sidebar-border: rgba(255,255,255,.06);
            --sidebar-text: #94a3b8;
            --sidebar-hover: rgba(255,255,255,.05);
            --sidebar-active: rgba(37,99,235,.15);
            --sidebar-active-text: #93c5fd;
            --radius: 12px;
            --radius-sm: 8px;
            --shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md: 0 4px 12px rgba(0,0,0,.08);
        }

        body {
            font-family: 'Geist', -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ══ SIDEBAR ══════════════════════════════════════════════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--sidebar-border);
        }

        .sidebar-brand {
            padding: 1.1rem 1.25rem;
            border-bottom: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: .65rem;
        }

        .brand-mark {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 0 0 1px rgba(255,255,255,.1) inset;
        }

        .brand-name {
            color: #f1f5f9;
            font-weight: 600;
            font-size: .9rem;
            letter-spacing: -.01em;
        }

        .nav-section-label {
            color: #475569;
            font-size: .65rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: 1rem 1.25rem .4rem;
        }

        .nav-item {
            color: var(--sidebar-text);
            border-radius: var(--radius-sm);
            padding: .55rem .9rem;
            display: flex;
            align-items: center;
            gap: .65rem;
            font-size: .835rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .12s, color .12s;
            margin: .1rem .6rem;
        }

        .nav-item i { font-size: .95rem; width: 18px; text-align: center; }
        .nav-item:hover { background: var(--sidebar-hover); color: #e2e8f0; }
        .nav-item.active { background: var(--sidebar-active); color: var(--sidebar-active-text); }
        .nav-item.active i { color: #60a5fa; }

        .nav-badge {
            margin-left: auto;
            background: rgba(255,255,255,.08);
            color: #94a3b8;
            font-size: .68rem;
            font-weight: 600;
            padding: .1rem .45rem;
            border-radius: 100px;
            font-family: 'Geist Mono', monospace;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 1rem 1.25rem;
            border-top: 1px solid var(--sidebar-border);
            font-size: .75rem;
            color: #475569;
        }

        /* ══ MAIN ══════════════════════════════════════════════════════════════ */
        .main {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
        }

        /* ══ TOPBAR ═══════════════════════════════════════════════════════════ */
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.75rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .page-title { font-size: 1.1rem; font-weight: 600; color: var(--text); letter-spacing: -.02em; }
        .page-sub { font-size: .8rem; color: var(--muted); margin-top: .1rem; }

        .topbar-right { display: flex; align-items: center; gap: .75rem; }

        .btn-primary-s {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: .5rem 1rem;
            font-size: .82rem;
            font-weight: 500;
            font-family: 'Geist', sans-serif;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: .4rem;
            text-decoration: none;
            transition: background .12s, transform .1s;
        }

        .btn-primary-s:hover { background: #1d4ed8; color: #fff; transform: translateY(-1px); }

        .date-chip {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: .4rem .8rem;
            font-size: .78rem;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        /* ══ CONTENT ══════════════════════════════════════════════════════════ */
        .content { padding: 1.75rem; }

        /* ══ STAT CARDS ═══════════════════════════════════════════════════════ */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: .75rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.1rem;
            cursor: pointer;
            transition: border-color .15s, box-shadow .15s, transform .1s;
            text-decoration: none;
            display: block;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: var(--card-accent, #e2e8f0);
            border-radius: 2px 2px 0 0;
            opacity: 0;
            transition: opacity .15s;
        }

        .stat-card:hover {
            border-color: var(--border-strong);
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
            color: var(--text);
        }

        .stat-card:hover::before { opacity: 1; }
        .stat-card.active-filter { border-color: var(--card-accent, #2563eb); box-shadow: 0 0 0 3px var(--card-ring, #bfdbfe); }
        .stat-card.active-filter::before { opacity: 1; }

        .stat-icon {
            width: 34px; height: 34px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: .75rem;
            font-size: 1rem;
        }

        .stat-num {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text);
            line-height: 1;
            font-family: 'Geist Mono', monospace;
            letter-spacing: -.03em;
        }

        .stat-label {
            font-size: .72rem;
            color: var(--muted);
            margin-top: .3rem;
            font-weight: 500;
        }

        /* ══ FILTER BAR ═══════════════════════════════════════════════════════ */
        .filter-bar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .filter-label {
            font-size: .75rem;
            color: var(--muted);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: .4rem;
        }

        .filter-pills { display: flex; gap: .4rem; flex-wrap: wrap; }

        .filter-pill {
            padding: .35rem .8rem;
            border-radius: 100px;
            font-size: .75rem;
            font-weight: 500;
            text-decoration: none;
            border: 1px solid var(--border);
            color: var(--muted);
            background: var(--bg);
            transition: all .12s;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

        .filter-pill:hover { border-color: var(--border-strong); color: var(--text); }
        .filter-pill.active { background: var(--accent); border-color: var(--accent); color: #fff; }

        /* ══ TABLE CARD ═══════════════════════════════════════════════════════ */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .table-head-row {
            display: grid;
            grid-template-columns: 170px 1fr 130px 90px 120px 140px 90px 120px;
            gap: 1rem;
            padding: .75rem 1.25rem;
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
        }

        .th {
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--subtle);
        }

        .table-row {
            display: grid;
            grid-template-columns: 170px 1fr 130px 90px 120px 140px 90px 120px;
            gap: 1rem;
            padding: .85rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            align-items: center;
            transition: background .1s;
        }

        .table-row:last-child { border-bottom: none; }
        .table-row:hover { background: #f8fafc; }

        .tracking-id {
            font-family: 'Geist Mono', monospace;
            font-size: .72rem;
            color: var(--accent);
            font-weight: 500;
            background: var(--accent-light);
            padding: .25rem .6rem;
            border-radius: 6px;
            display: inline-block;
        }

        .recipient-name { font-size: .85rem; font-weight: 600; color: var(--text); }
        .recipient-phone { font-size: .72rem; color: var(--muted); margin-top: .1rem; }

        .city-text { font-size: .82rem; color: var(--text); }

        .order-chip {
            display: inline-flex;
            align-items: center;
            background: #f1f5f9;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: .2rem .55rem;
            font-size: .75rem;
            font-weight: 600;
            color: var(--muted);
            font-family: 'Geist Mono', monospace;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .3rem .7rem;
            border-radius: 100px;
            font-size: .72rem;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .status-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

        .eta-text { font-size: .8rem; color: var(--text); }
        .eta-overdue { color: #e11d48; font-weight: 600; }

        .agent-name { font-size: .8rem; color: var(--text); }
        .agent-none { font-size: .78rem; color: #cbd5e1; }

        .actions { display: flex; gap: .4rem; justify-content: flex-end; }

        .btn-sm-view {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .3rem .7rem;
            border-radius: 6px;
            font-size: .75rem;
            font-weight: 500;
            font-family: 'Geist', sans-serif;
            text-decoration: none;
            transition: all .12s;
            border: 1px solid var(--border);
            color: var(--muted);
            background: var(--surface);
        }

        .btn-sm-view:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }

        .btn-sm-track {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .3rem .7rem;
            border-radius: 6px;
            font-size: .75rem;
            font-weight: 500;
            font-family: 'Geist', sans-serif;
            text-decoration: none;
            transition: all .12s;
            border: 1px solid transparent;
            color: var(--accent);
            background: var(--accent-light);
        }

        .btn-sm-track:hover { background: var(--accent); color: #fff; }

        /* ══ EMPTY STATE ══════════════════════════════════════════════════════ */
        .empty-state {
            padding: 4rem 2rem;
            text-align: center;
        }

        .empty-icon {
            width: 56px; height: 56px;
            background: #f1f5f9;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem;
            margin: 0 auto 1rem;
            color: #94a3b8;
        }

        .empty-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: .4rem; }
        .empty-sub { font-size: .83rem; color: var(--muted); }

        /* ══ ALERTS ═══════════════════════════════════════════════════════════ */
        .alert-bar {
            padding: .75rem 1.25rem;
            border-radius: var(--radius-sm);
            font-size: .82rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: .6rem;
            margin-bottom: 1rem;
        }

        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }
        .alert-error   { background: #fff1f2; border: 1px solid #fecdd3; color: #be123c; }

        @@media (max-width: 1200px) {
            .stat-grid { grid-template-columns: repeat(3, 1fr); }
        }

        @@media (max-width: 900px) {
            .sidebar { transform: translateX(-100%); }
            .main { margin-left: 0; }
        }
    </style>
</head>
<body>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-mark">
            <i class="bi bi-truck-front-fill text-white" style="font-size:.85rem;"></i>
        </div>
        <span class="brand-name">DeliveryOps</span>
    </div>

    <div class="nav-section-label">Main</div>
    <a href="/Delivery/LiveMap" class="nav-item">
        <i class="bi bi-map"></i> Live Map
        @if (Model.Any(d => d.Status == "OutForDelivery"))
        {
            <span class="nav-badge">@Model.Count(d => d.Status == "OutForDelivery")</span>
        }
    </a>
    <a href="/Delivery" class="nav-item active">
        <i class="bi bi-grid-3x3-gap"></i> All Deliveries
        <span class="nav-badge">@Model.Count</span>
    </a>
    <a href="/Delivery?status=Pending" class="nav-item">
        <i class="bi bi-hourglass-split"></i> Pending
    </a>
    <a href="/Delivery?status=Shipped" class="nav-item">
        <i class="bi bi-truck"></i> In Transit
    </a>
    <a href="/Delivery?status=OutForDelivery" class="nav-item">
        <i class="bi bi-bicycle"></i> Out for Delivery
    </a>
    <a href="/Delivery?status=Delivered" class="nav-item">
        <i class="bi bi-check-circle"></i> Delivered
    </a>

    <div class="nav-section-label">Reports</div>
    <a href="/Delivery?status=Failed" class="nav-item">
        <i class="bi bi-x-circle"></i> Failed
        @if (Model.Any(d => d.Status == "Failed"))
        {
            <span class="nav-badge" style="background:rgba(225,29,72,.15);color:#fda4af;">@Model.Count(d => d.Status == "Failed")</span>
        }
    </a>

    <div class="sidebar-footer">
        <div style="color:#475569; font-size:.7rem;">DeliveryOps v2.0</div>
        <div style="margin-top:.25rem;">API: <span style="color:#4ade80;">●</span> Connected</div>
    </div>
</aside>

<!-- ══ MAIN ══ -->
<div class="main">

    <!-- Topbar -->
    <div class="topbar">
        <div>
            <div class="page-title">Delivery Management</div>
            <div class="page-sub">
                @Model.Count deliveries found
                @if (!string.IsNullOrEmpty(current) && current != "All")
                {
                    <span>— filtered by <strong>@StatusLabel(current)</strong></span>
                }
            </div>
        </div>
        <div class="topbar-right">
            <div class="date-chip">
                <i class="bi bi-calendar3" style="color:#94a3b8;"></i>
                @DateTime.Now.ToString("dd MMM yyyy")
            </div>
            <a href="/Delivery/LiveMap" class="btn-primary-s">
                <i class="bi bi-map-fill"></i> Live Map
            </a>
        </div>
    </div>

    <div class="content">

        @if (TempData["Success"] != null)
        {
            <div class="alert-bar alert-success">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-bar alert-error">
                <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
            </div>
        }

        <!-- ── Stat cards ── -->
        <div class="stat-grid">
            @{
                var allStyle = ("", "#0f172a", "#e2e8f0");
            }
            <!-- Total -->
            <a href="/Delivery" class="stat-card @(current == "All" ? "active-filter" : "")"
               style="--card-accent:#6366f1; --card-ring:#e0e7ff;">
                <div class="stat-icon" style="background:#eef2ff; color:#6366f1;">
                    <i class="bi bi-boxes"></i>
                </div>
                <div class="stat-num">@Model.Count</div>
                <div class="stat-label">Total</div>
            </a>

            @foreach (var s in statuses.Skip(1))
            {
                var (bg, fg, ring) = StatusStyle(s);
                var cnt = counts[s];
                <a href="/Delivery?status=@s"
                   class="stat-card @(current == s ? "active-filter" : "")"
                   style="--card-accent:@fg; --card-ring:@ring;">
                    <div class="stat-icon" style="background:@bg; color:@fg;">
                        <i class="bi @StatusIcon(s)"></i>
                    </div>
                    <div class="stat-num" style="color:@(cnt > 0 ? "var(--text)" : "#cbd5e1");">@cnt</div>
                    <div class="stat-label">@StatusLabel(s)</div>
                </a>
            }
        </div>

        <!-- ── Filter pills ── -->
        <div class="filter-bar">
            <span class="filter-label"><i class="bi bi-funnel"></i> Filter:</span>
            <div class="filter-pills">
                <a href="/Delivery" class="filter-pill @(current == "All" ? "active" : "")">All</a>
                @foreach (var s in statuses.Skip(1))
                {
                    <a href="/Delivery?status=@s" class="filter-pill @(current == s ? "active" : "")">
                        @StatusLabel(s)
                    </a>
                }
            </div>
        </div>

        <!-- ── Table ── -->
        <div class="table-card">
            <div class="table-head-row">
                <div class="th">Tracking ID</div>
                <div class="th">Recipient</div>
                <div class="th">City</div>
                <div class="th">Order</div>
                <div class="th">Status</div>
                <div class="th">Est. Delivery</div>
                <div class="th">Agent</div>
                <div class="th" style="text-align:right;">Actions</div>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                    <div class="empty-title">No deliveries found</div>
                    <div class="empty-sub">
                        @if (current != "All")
                        {
                            <span>No <strong>@StatusLabel(current)</strong> deliveries. <a href="/Delivery" style="color:var(--accent);">View all</a></span>
                        }
                        else
                        {
                            <span>No deliveries have been created yet.</span>
                        }
                    </div>
                </div>
            }
            else
            {
                @foreach (var d in Model)
                {
                    var (sBg, sFg, sRing) = StatusStyle(d.Status);
                    var overdue = d.EstimatedDeliveryDate < DateTime.UtcNow && d.Status != "Delivered";

                    <div class="table-row">
                        <!-- Tracking ID -->
                        <div>
                            <span class="tracking-id">@d.TrackingId</span>
                        </div>

                        <!-- Recipient -->
                        <div>
                            <div class="recipient-name">@d.RecipientName</div>
                            <div class="recipient-phone">@d.ContactPhone</div>
                        </div>

                        <!-- City -->
                        <div>
                            @{
                                var parts = d.FullAddress?.Split(',');
                                var city = parts?.Length > 1 ? parts[1].Trim() : (parts?.FirstOrDefault() ?? "—");
                            }
                            <div class="city-text">@city</div>
                        </div>

                        <!-- Order -->
                        <div>
                            <span class="order-chip">#@d.OrderId</span>
                        </div>

                        <!-- Status -->
                        <div>
                            <span class="status-badge" style="background:@sBg; color:@sFg; border-color:@sRing;">
                                <span class="status-dot" style="background:@sFg;"></span>
                                @StatusLabel(d.Status)
                            </span>
                        </div>

                        <!-- ETA -->
                        <div>
                            <div class="eta-text @(overdue ? "eta-overdue" : "")">
                                @if (overdue) { <i class="bi bi-exclamation-triangle-fill"></i> }
                                @d.EstimatedDeliveryDate.ToString("dd MMM yyyy")
                            </div>
                        </div>

                        <!-- Agent -->
                        <div>
                            @if (!string.IsNullOrEmpty(d.DeliveryAgentName))
                            {
                                <div class="agent-name">@d.DeliveryAgentName</div>
                            }
                            else
                            {
                                <span class="agent-none">—</span>
                            }
                        </div>

                        <!-- Actions -->
                        <div class="actions">
                            <a href="/Delivery/Details/@d.Id" class="btn-sm-view">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <a href="/Delivery/Tracking/@d.TrackingId" class="btn-sm-track">
                                <i class="bi bi-geo-alt"></i> Track
                            </a>
                        </div>
                    </div>
                }
            }
        </div>

    </div>
</div>

</body>
</html>
