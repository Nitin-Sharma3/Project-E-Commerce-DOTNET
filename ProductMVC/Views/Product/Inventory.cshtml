@model List<SellerMVC.Models.ProductViewModel>

<style>

    .inventory-card {
        background: linear-gradient(145deg,#12172b,#0b0f1e);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 14px;
        overflow: hidden;
        transition: all .25s ease;
    }

        .inventory-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.6);
        }

    .inventory-img {
        height: 200px;
        width: 100%;
        object-fit: cover;
    }

    .price {
        font-size: 20px;
        font-weight: 600;
        color: #4fd1c5;
    }

    .stock {
        font-size: 14px;
        color: #cbd5e1;
    }

    .desc {
        font-size: 14px;
        color: #94a3b8;
        height: 40px;
        overflow: hidden;
    }

    .inventory-actions {
        display: flex;
        gap: 8px;
    }

    .btn-edit {
        background: #f59e0b;
        border: none;
    }

    .btn-delete {
        background: #ef4444;
        border: none;
    }

</style>


<h2 class="mb-4">My Inventory</h2>

@if (!Model.Any())
{
    <div class="card shadow-lg border-0 text-center p-5 mt-4">

        <h3 class="mb-3">📦 Your inventory is empty</h3>

        <p class="text-muted">
            You haven't added any products yet. Start by adding your first product.
        </p>

        <a class="btn btn-primary btn-lg mt-3"
           href="/Product/Add">
            ➕ Add Your First Product
        </a>

    </div>
}
else
{

    <div class="row g-4">

        @foreach (var product in Model)
        {

            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="inventory-card h-100">

                    <img src="@product.ImageUrl1"
                         class="inventory-img" />

                    <div class="p-3">

                        <h5 class="text-white mb-1">
                            @product.Name
                        </h5>

                        <p class="desc">
                            @product.Description
                        </p>

                        <div class="price mb-1">
                            ₹@product.Price
                        </div>

                        <div class="stock mb-2">
                            Stock: @product.Stock
                        </div>

                        @if (product.Stock < 5)
                        {
                            <span class="badge bg-danger mb-3">Low Stock</span>
                        }

                        <div class="inventory-actions mt-2">

                            <a asp-controller="Product"
                               asp-action="Edit"
                               asp-route-id="@product.Id"
                               class="btn btn-edit btn-sm">
                                Edit
                            </a>

                            <a class="btn btn-delete btn-sm"
                               asp-action="Delete"
                               asp-route-id="@product.Id"
                               onclick="return confirm('Delete this product?')">
                                Delete
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        }

    </div>

}