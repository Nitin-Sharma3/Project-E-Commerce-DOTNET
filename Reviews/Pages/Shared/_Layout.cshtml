<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reviews</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background: #0f172a;
                color: #e2e8f0;
            }

            .app-shell {
                min-height: 100vh;
            }

            .app-card {
                background: #111827;
                border: 1px solid #1f2937;
                border-radius: 16px;
                box-shadow: 0 8px 24px rgba(15, 23, 42, 0.4);
                overflow: visible; /* IMPORTANT FIX */
            }

            .navbar-brand {
                font-weight: 700;
                letter-spacing: 0.5px;
            }

            .nav-link {
                color: rgba(255, 255, 255, 0.75) !important;
            }

                .nav-link:hover,
                .nav-link:focus,
                .nav-link.active {
                    color: #ffffff !important;
                }

            .btn-primary {
                background: #2563eb;
                border-color: #2563eb;
            }

            .form-control,
            .form-select {
                background: #0b1220;
                border-color: #1f2937;
                color: #e2e8f0;
            }

                .form-control::placeholder,
                .form-select::placeholder {
                    color: rgba(226, 232, 240, 0.6);
                }

                .form-control:focus,
                .form-select:focus {
                    background: #0b1220;
                    border-color: #2563eb;
                    color: #e2e8f0;
                    box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.25);
                }

            /* 🔥 FIX: Carousel buttons visibility + click */
            .carousel-control-prev,
            .carousel-control-next {
                width: 5%;
                opacity: 1;
                z-index: 10;
            }

            .carousel-control-prev-icon,
            .carousel-control-next-icon {
                filter: invert(1);
            }
    </style>
</head>

<body>
    <div class="app-shell d-flex flex-column">

        @* <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
            <div class="container">
                <a class="navbar-brand" href="/Reviews">Review Hub</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="/Reviews">Reviews</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Reviews/Create">Add Review</a></li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Review API
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" href="/api/review/product/1">GET /api/review/product/1</a></li>
                                <li><a class="dropdown-item" href="/api/review/summary/1">GET /api/review/summary/1</a></li>
                                <li><a class="dropdown-item" href="/api/review/1/vote?isHelpful=true">POST /api/review/1/vote</a></li>
                                <li><a class="dropdown-item" href="/api/review/1/report?reason=test">POST /api/review/1/report</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="/swagger">Swagger</a></li>
                            </ul>
                        </li>

                        <li class="nav-item"><a class="nav-link" href="/api/upload">Upload API</a></li>
                    </ul>
                </div>
            </div>
        </nav> *@

        <main class="container my-4 flex-grow-1">
            <div class="app-card p-4">
                @RenderBody()
            </div>
        </main>

        <footer class="text-center text-secondary py-3 small">
            Reviews service · powered by Razor Pages
        </footer>
    </div>

    <!-- 🔥 IMPORTANT: Bootstrap JS MUST be here -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>